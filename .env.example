# Backend
DATABASE_URL=sqlite:///./fx_trading.db
FRONTEND_ORIGIN=http://localhost:3000
LOG_LEVEL=INFO

# Live trading is blocked unless this is explicitly true.
ENABLE_LIVE_TRADING=false
LIVE_CONFIRMATION_PHRASE=LIVE TRADING ENABLED

# Auto-trading never starts on its own; this is documented as off for clarity.
# Starting the practice bot always requires an explicit action in the UI/API.
AUTO_TRADE_DEFAULT_ENABLED=false

# Broker secrets belong only on the backend.
OANDA_API_TOKEN=
OANDA_ACCOUNT_ID=
OANDA_ENV=practice
OANDA_API_URL=https://api-fxpractice.oanda.com

# Broker selection. Only "oanda" has a wired order path. "gmo" is Public read-only.
BROKER_PROVIDER=oanda

# GMO Coin 外国為替FX (Public read-only scaffold; NO real orders this phase).
# GMO forex has no demo environment, so orders stay disabled until explicitly enabled.
# Leave key/secret empty unless using the future Private read-only phase.
GMO_FX_API_KEY=
GMO_FX_API_SECRET=
GMO_FX_ENV=production
GMO_FX_READONLY=true
GMO_FX_ORDER_ENABLED=false
GMO_FX_MAX_UNITS=100

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
